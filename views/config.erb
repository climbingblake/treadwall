<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings - C.R.I.M.P</title>
  <!-- Google Fonts removed for offline use -->
  <!-- <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"> -->
  <style>
    :root {
      --bg-primary: #0a0a0a;
      --bg-secondary: #141414;
      --bg-tertiary: #1a1a1a;
      --text-primary: #ffffff;
      --text-secondary: #a0a0a0;
      --text-tertiary: #666666;
      --accent-blue: #3b82f6;
      --accent-green: #10b981;
      --accent-blue-glow: rgba(59, 130, 246, 0.3);
      --accent-green-glow: rgba(16, 185, 129, 0.3);
      --border: rgba(255, 255, 255, 0.08);
      --radius: 16px;
      --shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
      --transition: cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
    }

    header {
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(16px);
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 10, 10, 0.95);
    }

    header .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 48px;
      gap: 16px;
    }

    header .header-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    header .logo {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--text-primary);
      text-decoration: none;
    }

    header .logo:hover {
      color: var(--accent-blue);
    }

    .status-indicator {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      position: relative;
    }

    .status-indicator.connected {
      background: var(--accent-green);
      box-shadow: 0 0 20px var(--accent-green-glow);
      animation: pulse-connected 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .status-indicator.disconnected {
      background: #ef4444;
      box-shadow: 0 0 20px rgba(239, 68, 68, 0.3);
      animation: pulse-disconnected 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse-connected {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    @keyframes pulse-disconnected {
      0%, 100% {
        opacity: 1;
        transform: scale(1);
      }
      50% {
        opacity: 0.7;
        transform: scale(1.2);
      }
    }

    header nav {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .nav-link {
      padding: 10px 16px;
      min-height: 40px;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text-secondary);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s var(--transition);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
    }

    .nav-link:hover {
      background: var(--bg-tertiary);
      border-color: rgba(255, 255, 255, 0.16);
      color: var(--text-primary);
      transform: translateY(-1px);
    }

    .nav-link.active {
      background: linear-gradient(135deg, var(--accent-blue), var(--accent-green));
      border: none;
      color: white;
    }

    main {
      padding: 48px 0;
    }

    .page-title {
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }

    .page-subtitle {
      color: var(--text-secondary);
      font-size: 16px;
      margin-bottom: 48px;
    }

    .settings-grid {
      display: grid;
      gap: 32px;
    }

    .control-section {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 40px;
      transition: all 0.3s var(--transition);
    }

    .control-section:hover {
      border-color: rgba(255, 255, 255, 0.12);
    }

    .section-title {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 24px;
      letter-spacing: -0.01em;
    }

    .control-group {
      margin-bottom: 32px;
    }

    .control-group:last-child {
      margin-bottom: 0;
    }

    .control-label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 16px;
      color: var(--text-secondary);
    }

    .slider-group {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    input[type="number"] {
      width: 120px;
      padding: 12px 16px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text-primary);
      font-size: 14px;
      font-weight: 600;
      font-feature-settings: 'tnum';
      transition: all 0.2s var(--transition);
    }

    input[type="number"]:hover {
      border-color: rgba(255, 255, 255, 0.16);
    }

    input[type="number"]:focus {
      outline: none;
      border-color: var(--accent-blue);
      box-shadow: 0 0 0 3px var(--accent-blue-glow);
    }

    input[type="text"],
    input[type="password"] {
      width: 100%;
      padding: 10px;
      background: var(--bg-primary);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-primary);
      font-size: 13px;
      font-family: inherit;
      transition: all 0.2s var(--transition);
    }

    input[type="text"]:hover,
    input[type="password"]:hover {
      border-color: rgba(255, 255, 255, 0.16);
    }

    input[type="text"]:focus,
    input[type="password"]:focus {
      outline: none;
      border-color: var(--accent-blue);
      box-shadow: 0 0 0 3px var(--accent-blue-glow);
    }

    button {
      padding: 14px 24px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s var(--transition);
      position: relative;
      overflow: hidden;
    }

    button::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 0;
      height: 0;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.1);
      transform: translate(-50%, -50%);
      transition: width 0.6s, height 0.6s;
    }

    button:active::before {
      width: 300px;
      height: 300px;
    }

    button:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent-blue), var(--accent-green));
      color: white;
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .btn-primary:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
    }

    .btn-secondary {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      border: 1px solid var(--border);
    }

    .btn-secondary:hover:not(:disabled) {
      background: var(--bg-secondary);
      border-color: rgba(255, 255, 255, 0.16);
      transform: translateY(-2px);
    }

    .btn-danger {
      background: linear-gradient(135deg, #ef4444, #dc2626);
      color: white;
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
      font-weight: 700;
    }

    .btn-danger:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(239, 68, 68, 0.4);
    }

    .info-grid {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 8px 16px;
      font-size: 12px;
      color: var(--text-secondary);
    }

    .info-grid span:first-child {
      font-weight: 600;
    }

    .info-box {
      background: var(--bg-tertiary);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 12px;
    }

    .input-group {
      margin-bottom: 12px;
    }

    .input-label {
      display: block;
      font-size: 11px;
      color: var(--text-tertiary);
      margin-bottom: 4px;
      font-weight: 600;
    }

    .status-text {
      font-size: 11px;
      color: var(--text-tertiary);
      margin-top: 8px;
      text-align: center;
      display: none;
    }

    .status-text.show {
      display: block;
    }

    .warning-text {
      font-size: 11px;
      color: #ef4444;
      margin-top: 8px;
      text-align: center;
      font-weight: 600;
    }

    .help-text {
      font-size: 12px;
      color: var(--text-tertiary);
      margin-top: 8px;
      margin-bottom: 12px;
      text-align: center;
    }

    @media (max-width: 768px) {
      .container { padding: 0 16px; }
      header { padding: 12px 0; }
      header .logo { font-size: 18px; }
      .nav-link {
        padding: 8px 12px;
        font-size: 13px;
      }
      .control-section {
        padding: 20px;
        margin: 0;
        border-radius: 12px;
      }
      main { padding: 24px 0; }
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <div class="header-left">
        <a href="/" class="logo">C.R.I.M.P</a>
        <div class="status-indicator connected" id="status-indicator"></div>
      </div>
      <nav>
        <a href="/" class="nav-link">Home</a>
        <a href="/config" class="nav-link active">Settings</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <h1 class="page-title">Settings</h1>
    <p class="page-subtitle">Configure system, network, and motor settings</p>

    <div class="settings-grid">
      <!-- Increment Step Configuration -->
      <div class="control-section">
        <h2 class="section-title">Increment Step</h2>
        <div class="control-group">
          <label class="control-label">Step Increment Value</label>
          <div class="slider-group">
            <input type="number" id="stepper-increment-input" min="1" max="<%= MAX_POSITION %>" value="<%= CONFIG['stepper']['step_increment'] %>" style="flex: 1;">
            <button class="btn-secondary" onclick="setStepperIncrement()">Update</button>
          </div>
          <p class="help-text">Controls the increment/decrement amount for quick controls</p>
        </div>
      </div>

      <!-- Motor Position Limits -->
      <div class="control-section">
        <h2 class="section-title">Motor Position Limits</h2>
        <div class="control-group">
          <label class="control-label">Minimum Position</label>
          <div class="slider-group">
            <input type="number" id="min-position-input" min="0" max="1000000" value="<%= MIN_POSITION %>" style="flex: 1;">
            <button class="btn-secondary" onclick="setMinPosition()">Update</button>
          </div>
          <p class="help-text">Lowest allowed position (usually 0)</p>
        </div>
        <div class="control-group">
          <label class="control-label">Maximum Position</label>
          <div class="slider-group">
            <input type="number" id="max-position-input" min="0" max="1000000" value="<%= MAX_POSITION %>" style="flex: 1;">
            <button class="btn-secondary" onclick="setMaxPosition()">Update</button>
          </div>
          <p class="help-text">Highest allowed position (based on your hardware limits)</p>
        </div>
        <p id="position-limits-status" class="status-text"></p>
      </div>

      <!-- Calibration -->
      <div class="control-section">
        <h2 class="section-title">Calibration</h2>
        <div class="control-group">
          <button class="btn-secondary" onclick="resetPosition()" style="width: 100%;">Reset Position to Zero</button>
          <p class="help-text">
            Sets the current position as zero without moving the motor
          </p>
          <div style="display: flex; gap: 12px;">
            <button class="btn-danger" onclick="calibrateDecrement()" style="flex: 1; font-size: 13px;">
              ⚠ -1000 Steps
            </button>
            <button class="btn-danger" onclick="calibrateIncrement()" style="flex: 1; font-size: 13px;">
              ⚠ +1000 Steps
            </button>
          </div>
          <p class="warning-text">
            DANGER: Bypasses min/max limits
          </p>
        </div>
      </div>

      <!-- Network Configuration -->
      <div class="control-section">
        <h2 class="section-title">Network Configuration</h2>

        <!-- Network Status -->
        <div class="control-group">
          <label class="control-label">Connection Status</label>
          <div class="info-box">
            <div class="info-grid">
              <span>Mode:</span>
              <span id="network-mode-desc" style="font-weight: 600; color: var(--text-primary);">Loading...</span>
              <span>IP Address:</span>
              <span id="network-ip" style="font-weight: 600; color: var(--text-primary);">-</span>
              <span>Interface:</span>
              <span id="network-interface">-</span>
              <span>Internet:</span>
              <span id="network-internet">-</span>
            </div>
            <p class="help-text" style="margin-top: 12px; margin-bottom: 0; text-align: left;">
              <strong>WiFi Client Mode:</strong> Connected to home WiFi network<br>
              <strong>USB Tethering Mode:</strong> Connected via USB to phone (fallback when WiFi unavailable)
            </p>
          </div>
        </div>

        <!-- WiFi Configuration -->
        <div class="control-group">
          <label class="control-label">WiFi Credentials</label>
          <div class="info-box">
            <div class="info-grid" style="margin-bottom: 16px;">
              <span>Configured SSID:</span>
              <span id="wifi-configured-ssid" style="font-weight: 600; color: var(--text-primary);">Not configured</span>
              <span>Current WiFi:</span>
              <span id="wifi-current-ssid">Not connected</span>
              <span>Signal:</span>
              <span id="wifi-signal">-</span>
            </div>
            <div class="input-group">
              <label class="input-label">WiFi SSID</label>
              <input type="text" id="wifi-ssid-input" placeholder="Enter network name (e.g., Farmhouse)">
            </div>
            <div class="input-group">
              <label class="input-label">WiFi Password</label>
              <input type="password" id="wifi-password-input" placeholder="Enter password">
            </div>
            <button class="btn-primary" onclick="updateWifiCredentials()" style="width: 100%;">
              Update WiFi Credentials
            </button>
            <p class="help-text" style="margin-top: 8px; margin-bottom: 0;">
              After updating, Pi will attempt to connect. If connection fails, USB access remains available.
            </p>
            <p id="wifi-config-status" class="status-text">
              Updating...
            </p>
          </div>
        </div>
      </div>

      <!-- System Information -->
      <div class="control-section">
        <h2 class="section-title">System</h2>
        <div class="control-group">
          <div class="info-box">
            <div class="info-grid">
              <span>Version:</span>
              <span id="system-version">Loading...</span>
              <span>Device ID:</span>
              <span id="system-device-id">-</span>
              <span>Uptime:</span>
              <span id="system-uptime">-</span>
            </div>
          </div>
          <button class="btn-secondary" onclick="checkForUpdates()" style="width: 100%; margin-bottom: 8px;">
            <span id="update-button-text">Check for Updates</span>
          </button>
          <button id="update-button" class="btn-primary" onclick="triggerUpdate()" style="width: 100%; display: none;">
            Update Available - Click to Install
          </button>
          <p id="update-status" class="status-text">
            Update in progress...
          </p>
        </div>
      </div>
    </div>
  </main>

  <script src="/app.js"></script>
</body>
</html>
